{
  "name": "sandwich",
  "version": "0.2.0",
  "description": "Composable agent stack for software agencies",
  "type": "module",
  "keywords": [
    "pi-package",
    "claude-plugin",
    "sandwich",
    "order",
    "prd",
    "plan"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/etalasaccounts/sandwich.git"
  },
  "scripts": {
    "test": "node --experimental-strip-types plan/lib/validation.selfcheck.ts && node --experimental-strip-types registry/registry.selfcheck.ts && node --experimental-strip-types order/lib/validation.selfcheck.ts"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "pi": {
    "extensions": [
      "./order/pi-extension/order.ts",
      "./plan/pi-extension/plan.ts",
      "./spec/pi-extension/spec.ts"
    ],
    "skills": [
      "./order/skills/order",
      "./plan/skills/plan",
      "./plan/skills/status",
      "./spec/skills/recipe"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
